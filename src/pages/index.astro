---
import Container from "@/components/container.astro";
import Cta from "@/components/cta.astro";
import Features from "@/components/features.astro";
import Hero from "@/components/hero.astro";
import Logos from "@/components/logos.astro";
import Layout from "@/layouts/Layout.astro";
import CaraOrder from "@/components/caraorder.astro";
import Faq from "@/components/faq.astro";
---

<Layout title="SiPintar — Jasa Joki Tugas & Karya Ilmiah Terpercaya">
  <Container>
    <!-- Bagian Utama / Hero -->
    <Hero />
    
    <!-- Bagian Partner / Software Akademik -->
    <Logos />

    <!-- 1. BAGIAN LAYANAN -->
    <div id="layanan" class="scroll-mt-20">
      <Features />
    </div>

    <!-- 2. BAGIAN CARA ORDER -->
    <!-- Placeholder: Berfungsi agar tombol Navbar Cara Order aktif -->
    <div id="cara-order" class="scroll-mt-20">
      <CaraOrder />
    </div>

    <!-- 3. BAGIAN TESTIMONI -->
    <!-- Placeholder: Tempat untuk galeri screenshot WhatsApp testimoni nanti -->
    <div id="testimoni" class="scroll-mt-20 my-24 text-center">
      <!-- Nanti galeri screenshot WA testimoni ditaruh di sini -->
    </div>

    <!-- Banner Garansi & CTA Utama -->
    <Cta />

    <!-- 4. BAGIAN FAQ -->
    <!-- Placeholder: Berfungsi agar tombol Navbar FAQ aktif -->
    <div id="faq" class="scroll-mt-20 mb-20">
      <Faq />
    </div>
  </Container>
</Layout>

<style is:global>
  /* Menambahkan efek transisi bergeser halus (smooth scroll) ke seluruh halaman */
  html {
    scroll-behavior: smooth;
  }
</style>