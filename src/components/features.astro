---
// @ts-ignore
import { Icon } from "astro-icon/components";

const features = [
  {
    title: "Jasa Ketik Cepat & Rapi",
    description:
      "Layanan pengetikan dokumen, laporan, atau modul kuliah ke format Word, Excel, maupun PDF dengan format yang rapi dan minim typo.",
    icon: "bx:bx-laptop",
  },
  {
    title: "Jasa Tulis Tangan",
    description:
      "Solusi untuk tugas resume atau catatan di kertas folio/buku. Dikerjakan dengan tulisan yang bersih, rapi, dan mudah dibaca.",
    icon: "bx:bx-edit",
  },
  {
    title: "Jasa Makalah & Paper",
    description:
      "Penyusunan makalah kelompok atau individu dari nol. Dilengkapi dengan struktur akademik yang benar dan referensi valid.",
    icon: "bx:bx-copy-alt",
  },
  {
    title: "Jasa Presentasi (PPT)",
    description:
      "Pembuatan slide PowerPoint (PPT) yang menarik, modern, dan interaktif untuk kebutuhan presentasi harian maupun materi sidang.",
    icon: "bx:bx-slideshow",
  },
  {
    title: "Bantuan Tugas Harian",
    description:
      "Membantu menyelesaikan berbagai tugas harian kuliah atau sekolah, mulai dari hitungan, rangkuman materi, hingga soal latihan.",
    icon: "bx:bx-task",
  },
  {
    title: "Proposal & Skripsi",
    description:
      "Pendampingan pengerjaan Tugas Akhir atau Skripsi, baik secara parsial (per Bab) maupun full dari awal hingga bab kesimpulan.",
    icon: "bx:bx-book-bookmark",
  },
  {
    title: "Jasa Translate Terpercaya",
    description:
      "Penerjemahan dokumen akademik, abstrak skripsi, atau jurnal ilmiah dari bahasa Inggris ke Indonesia (dan sebaliknya) secara natural.",
    icon: "bx:bx-globe",
  },
  {
    title: "Jasa Buat Jurnal Ilmiah",
    description:
      "Bantu konversi laporan penelitian atau skripsimu menjadi artikel jurnal ilmiah yang siap submit ke jurnal nasional maupun internasional.",
    icon: "bx:bx-file",
  },
];
---

<div class="mt-16 md:mt-24 text-center">
  <h2 class="text-4xl lg:text-5xl font-bold lg:tracking-tight">
    Layanan Terbaik untuk Tugas Kuliah & Sekolahmu
  </h2>
  <p class="text-lg mt-4 text-slate-600 max-w-xl mx-auto">
    Kami menyediakan berbagai layanan pengerjaan tugas akademik yang dikerjakan oleh tim ahli secara cepat, rapi, dan rahasia terjamin. Pilih layanan yang kamu butuhkan sekarang!
  </p>
</div>

<div class="grid sm:grid-cols-2 md:grid-cols-4 mt-16 gap-x-8 gap-y-12">
  {
    features.map((item) => (
      <div class="flex flex-col items-center text-center p-6 bg-white rounded-xl border border-slate-100 shadow-sm hover:shadow-md transition">
        <div class="mb-4 bg-blue-600 rounded-full p-3 w-12 h-12 flex items-center justify-center shrink-0 shadow-sm shadow-blue-200">
          <Icon class="text-white text-xl" name={item.icon} />
        </div>
        <div>
          <h3 class="font-semibold text-lg text-slate-800">{item.title}</h3>{" "}
          <p class="text-slate-500 mt-2 text-sm leading-relaxed">{item.description}</p>
        </div>
      </div>
    ))
  }
</div>

<div class="mt-12 bg-blue-600 text-white rounded-xl p-4 text-center font-bold text-lg md:text-xl tracking-wide uppercase shadow-md shadow-blue-200">
  🔥 Menerima Semua Jenis Mata Pelajaran / Kuliah! 🔥
</div>